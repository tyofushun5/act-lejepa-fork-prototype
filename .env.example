# Weights & Biases
# WANDB_MODE: online (upload; requires WANDB_API_KEY or `wandb login`),
#             offline (write to local ./wandb only; no login required),
#             disabled (no logging at all).
# A value set in the shell takes precedence over this file:
#   WANDB_MODE=offline python -m scripts.train --config_path ...
WANDB_MODE=online
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=act-jepa-revision
WANDB_SILENT=true
WANDB_WATCH=all

# Hugging Face
# Optional for public datasets/models; required for private repos or authenticated uploads.
HF_TOKEN=your_huggingface_token_here
HF_HOME=/tmp/huggingface_cache
